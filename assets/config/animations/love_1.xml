<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>

    <block type="eye_background">
        <field name="type">IMAGE</field>
        <field name="style">HEARTS</field>
        <field name="eye_side">2</field>
        <field name="duration_ms">5000</field>
        <field name="start">1</field>
    </block>
    <block type="overlay_animation">
        <sequence_animations name="hearts" loop_count="1" fps="15" side="BOTH" speed="1.0" clear_time="5000" />
        <field name="delay_ms">0</field>
        <field name="start">1</field>
    </block>
    <block type="sound">
        <field name="type_id">SFX</field>
        <field name="delay_ms">100</field>
        <field name="name">KISS_1</field>
        <field name="start">0</field>
    </block>
    <block type="led_animation">
