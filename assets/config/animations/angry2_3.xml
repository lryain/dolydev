<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="led">
        <field name="color_main">#ff0000</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">STORMING</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">ANGRY (4)</field>
        <field name="start">0</field>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">0</field>
        <field name="speed">10</field>
        <field name="direction">0</field>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">1</field>
        <field name="speed">10</field>
        <field name="direction">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">1500</field>
        <field name="start">1</field>
    </block>
    <block type="drive_rotate_right">
        <field name="driveRotate">3</field>
        <field name="isCenter">TRUE</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">750</field>
        <field name="start">1</field>
    </block>
    <block type="drive_rotate_left">
        <field name="driveRotate">6</field>
        <field name="isCenter">TRUE</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">2250</field>
        <field name="start">1</field>
    </block>
    <block type="drive_rotate_right">
        <field name="driveRotate">3</field>
        <field name="isCenter">TRUE</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">750</field>
        <field name="start">1</field>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">1</field>
        <field name="speed">10</field>
        <field name="direction">1</field>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">1</field>
        <field name="speed">10</field>
        <field name="direction">0</field>
    </block>
    <block type="led">
        <field name="color_main">#000000</field>
        <field name="side">0</field>
        <field name="start">1</field>
    </block>
</xml>