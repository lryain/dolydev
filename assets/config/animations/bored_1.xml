<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">SAD (4)</field>
        <field name="start">1</field>
    </block>
    <block type="repeat">
        <field name="times">3</field>
        <field name="start">0</field>
        <statement name="repeat_statement">
            <block type="eye_animations">
                <field name="category">DEPRESSION</field>
                <field name="animation">BLUE</field>
                <field name="start">0</field>
            </block>
            <block type="drive_rotate_left">
                <field name="driveRotate">20</field>
                <field name="isCenter">FALSE</field>
                <field name="start">0</field>
                <field name="speed">5</field>
                <field name="accel">20</field>
                <field name="brake">0</field>
            </block>
            <block type="drive_rotate_right">
                <field name="driveRotate">20</field>
                <field name="isCenter">FALSE</field>
                <field name="start">1</field>
                <field name="speed">5</field>
                <field name="accel">20</field>
                <field name="brake">0</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">2500</field>
                <field name="start">1</field>
            </block>
            <block type="drive_rotate_right">
                <field name="driveRotate">20</field>
                <field name="isCenter">FALSE</field>
                <field name="start">1</field>
                <field name="speed">5</field>
                <field name="accel">20</field>
                <field name="brake">0</field>
                <field name="direction">0</field>
            </block>
            <block type="drive_rotate_left">
                <field name="driveRotate">20</field>
                <field name="isCenter">FALSE</field>
                <field name="start">1</field>
                <field name="speed">5</field>
                <field name="accel">20</field>
                <field name="brake">0</field>
                <field name="direction">0</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">2500</field>
                <field name="start">1</field>
            </block>
        </statement>
    </block>
</xml>