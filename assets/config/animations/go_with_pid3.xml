<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">AGREE (10)</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">BLINK</field>
        <field name="start">0</field>
    </block>
    
    <block type="delay_ms">
        <field name="delay_ms">100</field>
        <field name="start">1</field>
    </block>
    <block type="turn_deg_pid">
        <field name="driveRotate">90</field>
        <field name="isCenter">TRUE</field>
        <field name="start">1</field>
        <field name="speed">50</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">2000</field>
        <field name="start">1</field>
    </block>    
    <block type="turn_deg_pid">
        <field name="driveRotate">-90</field>
        <field name="isCenter">TRUE</field>
        <field name="start">1</field>
        <field name="speed">50</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">100</field>
        <field name="start">1</field>
    </block>
    
</xml>