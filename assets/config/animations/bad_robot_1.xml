<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">FUMING L</field>
        <field name="start">1</field>
    </block>
    <block type="drive_rotate_left">
        <field name="driveRotate">2</field>
        <field name="isCenter">TRUE</field>
        <field name="start">0</field>
        <field name="speed">100</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">150</field>
        <field name="side">1</field>
        <field name="start">0</field>
        <field name="speed">100</field>
        <field name="brake">0</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">2</field>
        <field name="start">0</field>
        <field name="speed">100</field>
        <field name="brake">0</field>
    </block>
    <block type="led">
        <field name="color_main">#ff0000</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">ATTACK (15)</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">FUMING R</field>
        <field name="start">1</field>
    </block>
    <block type="drive_rotate_right">
        <field name="driveRotate">2</field>
        <field name="isCenter">TRUE</field>
        <field name="start">0</field>
        <field name="speed">100</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">1000</field>
        <field name="start">0</field>
    </block>
    <block type="repeat">
        <field name="times">2</field>
        <field name="start">1</field>
        <statement name="repeat_statement">
            <block type="arm_set_angle">
                <field name="angle">75</field>
                <field name="side">2</field>
                <field name="start">1</field>
                <field name="brake">0</field>
            </block>
            <block type="led">
                <field name="color_main">#000000</field>
                <field name="side">2</field>
                <field name="start">1</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">100</field>
                <field name="start">1</field>
            </block>
            <block type="arm_set_angle">
                <field name="angle">90</field>
                <field name="side">2</field>
                <field name="start">1</field>
                <field name="brake">0</field>
            </block>
            <block type="led">
                <field name="color_main">#ff0000</field>
                <field name="side">2</field>
                <field name="start">0</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">100</field>
                <field name="start">1</field>
            </block>
        </statement>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">500</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">1</field>
        <field name="start">0</field>
        <field name="speed">100</field>
        <field name="brake">0</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">150</field>
        <field name="side">2</field>
        <field name="start">0</field>
        <field name="speed">100</field>
        <field name="brake">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">ATTACK (5)</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">FUMING L</field>
        <field name="start">0</field>
    </block>
    <block type="drive_rotate_left">
        <field name="driveRotate">2</field>
        <field name="isCenter">TRUE</field>
        <field name="start">0</field>
        <field name="speed">100</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">2000</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">0</field>
        <field name="side">0</field>
        <field name="start">1</field>
        <field name="speed">100</field>
        <field name="brake">0</field>
    </block>
    <block type="led_animation_color">
        <field name="color_main">#ff0000</field>
        <field name="led_time">3000</field>
    </block>
</xml>