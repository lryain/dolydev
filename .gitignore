## Repository-level .gitignore
# Ignore Python virtualenvs (including the top-level .venv)
.venv/
logs
libs/FaceReco/videos
libs/FaceReco/captures
venv/
ENV/
.env/
logs
libs/tts/edge-tts/files

**/node_modules
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/

# PyTest cache
.pytest_cache/

# Editor directories and files
.vscode/
.idea/
*.swp
*~

# Local data
.DS_Store
Thumbs.db

# End
**/.log
