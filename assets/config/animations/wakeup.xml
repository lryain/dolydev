<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">SLEEPY</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">750</field>
        <field name="start">0</field>
    </block>
    <block type="led_animation">
        <field name="start">0</field>
        <statement name="led_left">
            <block type="led_animation_color">
                <field name="color_main">#000000</field>
                <field name="led_time">3500</field>
                <field name="color_fade">#ffffff</field>
            </block>
        </statement>
        <statement name="led_right">
            <block type="led_animation_color">
                <field name="color_main">#000000</field>
                <field name="led_time">3500</field>
                <field name="color_fade">#ffffff</field>
            </block>
        </statement>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">YAWN (4)</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">LOOK UP L</field>
        <field name="start">1</field>
    </block>
    <block type="led">
        <field name="color_main">#000000</field>
        <field name="side">0</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">0</field>
        <field name="side">0</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">BLINK</field>
        <field name="start">1</field>
    </block>
</xml>