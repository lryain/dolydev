<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="repeat">
        <field name="times">3</field>
        <field name="start">1</field>
        <statement name="repeat_statement">
            <block type="drive_rotate_right">
                <field name="driveRotate">15</field>
                <field name="isCenter">TRUE</field>
                <field name="start">0</field>
            </block>
            <block type="eye_animations">
                <field name="category">HAPPINESS</field>
                <field name="animation">MOODY LR</field>
                <field name="start">0</field>
            </block>
            <block type="drive_rotate_left">
                <field name="driveRotate">15</field>
                <field name="isCenter">TRUE</field>
                <field name="start">1</field>
            </block>
            <block type="eye_animations">
                <field name="category">HAPPINESS</field>
                <field name="animation">MOODY RL</field>
                <field name="start">0</field>
            </block>
        </statement>
    </block>
    <block type="eye_animations">
        <field name="category">HAPPINESS</field>
        <field name="animation">OVERJOYED</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">500</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">LAUGH (13)</field>
        <field name="start">1</field>
    </block>
</xml>