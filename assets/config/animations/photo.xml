<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">INTERNAL</field>
        <field name="animation">PHOTO</field>
        <field name="start">1</field>
    </block>
    <block type="overlay_animation">
        <sequence_animations name="camera" loop_count="1" fps="15" side="RIGHT" speed="1.0" clear_time="500" />
        <field name="delay_ms">0</field>
        <field name="start">0</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">1</field>
        <field name="start">0</field>
    </block>
    <block type="repeat">
        <field name="times">3</field>
        <field name="start">0</field>
        <statement name="repeat_statement">
            <block type="led_animation">
                <field name="start">0</field>
                <statement name="led_left">
                    <block type="led_animation_color">
                        <field name="color_main">#ffffff</field>
                        <field name="led_time">100</field>
                    </block>
                    <block type="led_animation_color">
                        <field name="color_main">#ff0000</field>
                        <field name="led_time">100</field>
                    </block>
                </statement>
                <statement name="led_right">
                    <block type="led_animation_color">
                        <field name="color_main">#ff0000</field>
                        <field name="led_time">100</field>
                    </block>
                    <block type="led_animation_color">
                        <field name="color_main">#ffffff</field>
                        <field name="led_time">100</field>
                    </block>
                </statement>
            </block>
        </statement>
    </block>
    <block type="sound">
        <field name="type_id">SFX</field>
        <field name="delay_ms">1500</field>
        <field name="name">CAMERA CLICK</field>
        <field name="start">0</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">100</field>
        <field name="start">1</field>
    </block>
    <block type="led_animation_color">
        <field name="color_main">#ffffff</field>
        <field name="led_time">1000</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">1000</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">0</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
</xml>