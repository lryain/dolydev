<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">CONFUSION</field>
        <field name="animation">UNCOMFORTABLE</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">2500</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">IDLE (2)</field>
        <field name="start">1</field>
    </block>
    <block type="led_animation">
        <field name="start">1</field>
        <statement name="led_left">
            <block type="led_animation_color">
                <field name="color_main">#ffffff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ffff00</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ffff00</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ff0000</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ff0000</field>
                <field name="led_time">400</field>
                <field name="color_fade">#00ff00</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#00ff00</field>
                <field name="led_time">400</field>
                <field name="color_fade">#0000ff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#0000ff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#6600cc</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#6600cc</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ff00ff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ff00ff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#66ffff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#66ffff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ffffff</field>
            </block>
        </statement>
        <statement name="led_right">
            <block type="led_animation_color">
                <field name="color_main">#ffffff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ffff00</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ffff00</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ff0000</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ff0000</field>
                <field name="led_time">400</field>
                <field name="color_fade">#00ff00</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#00ff00</field>
                <field name="led_time">400</field>
                <field name="color_fade">#0000ff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#0000ff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#6600cc</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#6600cc</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ff00ff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#ff00ff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#66ffff</field>
            </block>
            <block type="led_animation_color">
                <field name="color_main">#66ffff</field>
                <field name="led_time">400</field>
                <field name="color_fade">#ffffff</field>
            </block>
        </statement>
    </block>
    <block type="drive_rotate_right">
        <field name="driveRotate">350</field>
        <field name="isCenter">TRUE</field>
        <field name="start">0</field>
        <field name="speed">100</field>
        <field name="accel">10</field>
        <field name="brake">0</field>
        <statement name="complete_statement">
            <block type="led_animation">
                <field name="start">1</field>
                <statement name="led_left">
                    <block type="led_animation_color">
                        <field name="color_main">#ffffff</field>
                        <field name="led_time">3000</field>
                        <field name="color_fade">#000000</field>
                    </block>
                </statement>
                <statement name="led_right">
                    <block type="led_animation_color">
                        <field name="color_main">#ffffff</field>
                        <field name="led_time">3000</field>
                        <field name="color_fade">#000000</field>
                    </block>
                </statement>
            </block>
            <block type="arm_set_angle">
                <field name="angle">0</field>
                <field name="side">0</field>
                <field name="start">1</field>
            </block>
        </statement>
    </block>
    <block type="eye_animations">
        <field name="category">CONFUSION</field>
        <field name="animation">THROWN</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">HAPPINESS</field>
        <field name="animation">EXCITED</field>
        <field name="start">1</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">LAUGH (17)</field>
        <field name="start">0</field>
    </block>
</xml>