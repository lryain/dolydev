<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="repeat">
        <field name="times">3</field>
        <field name="start">1</field>
        <statement name="repeat_statement">
            <block type="drive_distance">
                <field name="distance">20</field>
                <field name="speed">30</field>
                <field name="accel">0</field>
                <field name="brake">0</field>
                <field name="start">1</field>
            </block>
            <block type="sound">
                <field name="type_id">DOLY</field>
                <field name="name">IDLE (7)</field>
                <field name="start">0</field>
            </block>
            <block type="eye_animations">
                <field name="category">HURT</field>
                <field name="animation">GET BIGGER</field>
                <field name="start">0</field>
            </block>
            <block type="drive_distance">
                <field name="distance">20</field>
                <field name="speed">30</field>
                <field name="accel">0</field>
                <field name="brake">0</field>
                <field name="start">1</field>
                <field name="direction">0</field>
            </block>
            <block type="eye_animations">
                <field name="category">HURT</field>
                <field name="animation">GET SMALLER</field>
                <field name="start">0</field>
            </block>
        </statement>
    </block>
    <block type="eye_animations">
        <field name="category">HAPPINESS</field>
        <field name="animation">ADMIRING</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">250</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">LAUGH (12)</field>
        <field name="start">1</field>
    </block>
</xml>