<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="led">
        <field name="color_main">#ff0000</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="drive_distance">
        <field name="distance">15</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">OUTRAGED</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">ANGRY (13)</field>
        <field name="start">0</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">1000</field>
        <field name="start">1</field>
    </block>
    <block type="led_animation">
        <field name="start">1</field>
        <statement name="led_left">
            <block type="led_animation_color">
                <field name="color_main">#ff0000</field>
                <field name="led_time">750</field>
                <field name="color_fade">#000000</field>
            </block>
        </statement>
        <statement name="led_right">
            <block type="led_animation_color">
                <field name="color_main">#ff0000</field>
                <field name="led_time">750</field>
                <field name="color_fade">#000000</field>
            </block>
        </statement>
    </block>
</xml>