<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">CONFUSION</field>
        <field name="animation">GET BIGGER</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">ANGER</field>
        <field name="animation">BUGGED</field>
        <field name="start">1</field>
    </block>
    <block type="repeat">
        <field name="times">10</field>
        <field name="start">0</field>
        <statement name="repeat_statement">
            <block type="led">
                <field name="color_main">#ff6600</field>
                <field name="side">0</field>
                <field name="start">1</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">150</field>
                <field name="start">1</field>
            </block>
            <block type="led">
                <field name="color_main">#000000</field>
                <field name="side">0</field>
                <field name="start">1</field>
            </block>
            <block type="delay_ms">
                <field name="delay_ms">150</field>
                <field name="start">1</field>
            </block>
        </statement>
    </block>
</xml>