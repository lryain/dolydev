<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="sound">
        <field name="type_id">DOLY</field>
        <field name="name">SNEEZE (3)</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">SNEEZE</field>
        <field name="start">0</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">1500</field>
        <field name="start">0</field>
    </block>
    <block type="led_animation">
        <field name="start">1</field>
        <statement name="led_left">
            <block type="led_animation_color">
                <field name="color_main">#ffffff</field>
                <field name="led_time">1000</field>
                <field name="color_fade">#000000</field>
            </block>
        </statement>
        <statement name="led_right">
            <block type="led_animation_color">
                <field name="color_main">#ffffff</field>
                <field name="led_time">1000</field>
                <field name="color_fade">#000000</field>
            </block>
        </statement>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">0</field>
        <field name="speed">50</field>
        <field name="direction">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">LOOK LEFT</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">500</field>
        <field name="start">0</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">LOOK RIGHT</field>
        <field name="start">1</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">500</field>
        <field name="start">0</field>
    </block>
    <block type="drive_distance">
        <field name="distance">10</field>
        <field name="start">1</field>
        <field name="speed">50</field>
        <field name="direction">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">BLINK</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">BLINK SLOW</field>
        <field name="start">1</field>
    </block>
</xml>