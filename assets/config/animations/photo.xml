<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">INTERNAL</field>
        <field name="animation">PHOTO</field>
        <field name="start">1</field>
    </block>
    <block type="overlay_animation">
        <sequence_animations name="camera" loop_count="1" fps="15" side="RIGHT" speed="1.0" clear_time="500" />
        <field name="delay_ms">0</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">SFX</field>
        <field name="delay_ms">1500</field>
        <field name="name">CAMERA CLICK</field>
        <field name="start">0</field>
    </block>
    <block type="delay_ms">
        <field name="delay_ms">100</field>
        <field name="start">1</field>
    </block>

</xml>