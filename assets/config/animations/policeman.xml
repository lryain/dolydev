<xml xmlns="https://developers.google.com/blockly/xml">
    <block type="start_animation"></block>
    <block type="eye_animations">
        <field name="category">SPECIAL</field>
        <field name="animation">POLICE</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">90</field>
        <field name="side">0</field>
        <field name="start">0</field>
    </block>
    <block type="sound">
        <field name="type_id">SFX</field>
        <field name="name">POLICE_1</field>
        <field name="start">0</field>
    </block>
    <block type="repeat">
        <field name="times">14</field>
        <field name="start">0</field>
        <statement name="repeat_statement">
            <block type="led_animation">
                <field name="start">0</field>
                <statement name="led_left">
                    <block type="led_animation_color">
                        <field name="color_main">#ff0000</field>
                        <field name="led_time">250</field>
                    </block>
                    <block type="led_animation_color">
                        <field name="color_main">#0000ff</field>
                        <field name="led_time">250</field>
                    </block>
                </statement>
                <statement name="led_right">
                    <block type="led_animation_color">
                        <field name="color_main">#0000ff</field>
                        <field name="led_time">250</field>
                    </block>
                    <block type="led_animation_color">
                        <field name="color_main">#ff0000</field>
                        <field name="led_time">250</field>
                    </block>
                </statement>
            </block>
        </statement>
    </block>
    <block type="led">
        <field name="color_main">#000000</field>
        <field name="side">0</field>
        <field name="start">1</field>
    </block>
    <block type="arm_set_angle">
        <field name="angle">1</field>
        <field name="side">0</field>
        <field name="start">1</field>
    </block>
    <block type="eye_animations">
        <field name="category">MISC</field>
        <field name="animation">BLINK L</field>
        <field name="start">1</field>
    </block>
</xml>